{
	"info": {
		"name": "TatilSepeti Price Bot",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000"
		},
		{
			"key": "apiKey",
			"value": "test-api-key-123"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/health"
					}
				}
			]
		},
		{
			"name": "Fiyat Sorgulama",
			"item": [
				{
					"name": "Tek Otel Fiyat Sorgula",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/prices?hotelId=hotel-1&checkIn=19.05.2026&checkOut=30.05.2026&adults=3&children=0",
							"host": ["{{baseUrl}}"],
							"path": ["api", "prices"],
							"query": [
								{ "key": "hotelId", "value": "hotel-1" },
								{ "key": "checkIn", "value": "19.05.2026" },
								{ "key": "checkOut", "value": "30.05.2026" },
								{ "key": "adults", "value": "3" },
								{ "key": "children", "value": "0" }
							]
						}
					}
				},
				{
					"name": "Toplu Fiyat Sorgula",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/prices/bulk",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"hotelIds\": [\"hotel-1\", \"hotel-2\", \"hotel-3\"],\n  \"checkIn\": \"19.05.2026\",\n  \"checkOut\": \"30.05.2026\",\n  \"adults\": 3,\n  \"children\": 0\n}"
						}
					}
				}
			]
		},
		{
			"name": "Admin - Otel Eslestirme",
			"item": [
				{
					"name": "Tum Eslestirmeleri Listele",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/admin/mappings",
						"header": [
							{ "key": "x-api-key", "value": "{{apiKey}}" }
						]
					}
				},
				{
					"name": "Eslestirme Ara (search)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/admin/mappings?search=otel",
							"host": ["{{baseUrl}}"],
							"path": ["api", "admin", "mappings"],
							"query": [
								{ "key": "search", "value": "otel" }
							]
						},
						"header": [
							{ "key": "x-api-key", "value": "{{apiKey}}" }
						]
					}
				},
				{
					"name": "Sadece Aktif Eslestirmeler",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/api/admin/mappings?active=true",
							"host": ["{{baseUrl}}"],
							"path": ["api", "admin", "mappings"],
							"query": [
								{ "key": "active", "value": "true" }
							]
						},
						"header": [
							{ "key": "x-api-key", "value": "{{apiKey}}" }
						]
					}
				},
				{
					"name": "Tek Eslestirme Ekle",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/admin/mappings",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "x-api-key", "value": "{{apiKey}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"internalHotelId\": \"hotel-99\",\n  \"tatilsepetiHotelId\": \"12345\",\n  \"hotelName\": \"Ornek Otel\"\n}"
						}
					}
				},
				{
					"name": "Toplu Eslestirme Ekle",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/admin/mappings/bulk",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "x-api-key", "value": "{{apiKey}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"mappings\": [\n    {\n      \"internalHotelId\": \"hotel-10\",\n      \"tatilsepetiHotelId\": \"111\",\n      \"hotelName\": \"Otel A\"\n    },\n    {\n      \"internalHotelId\": \"hotel-11\",\n      \"tatilsepetiHotelId\": \"222\",\n      \"hotelName\": \"Otel B\"\n    },\n    {\n      \"internalHotelId\": \"hotel-12\",\n      \"tatilsepetiHotelId\": \"333\",\n      \"hotelName\": \"Otel C\"\n    }\n  ]\n}"
						}
					}
				},
				{
					"name": "Eslestirme Guncelle",
					"request": {
						"method": "PUT",
						"url": "{{baseUrl}}/api/admin/mappings/1",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "x-api-key", "value": "{{apiKey}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"hotelName\": \"Guncel Otel Adi\",\n  \"tatilsepetiHotelId\": \"99999\"\n}"
						}
					}
				},
				{
					"name": "Eslestirme Sil",
					"request": {
						"method": "DELETE",
						"url": "{{baseUrl}}/api/admin/mappings/1",
						"header": [
							{ "key": "x-api-key", "value": "{{apiKey}}" }
						]
					}
				}
			]
		}
	]
}
