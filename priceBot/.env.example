# Server
PORT=3000

# PostgreSQL
DATABASE_URL="postgresql://botuser:botpass123@localhost:5434/pricebot?schema=public"

# Admin API Key
ADMIN_API_KEY="your-secret-api-key-here"

# Provider cookies
ETSTUR_COOKIE=""
TATILSEPETI_COOKIE=""

# Proxy (Webshare.io) - static fallback
PROXY_HOST=""
PROXY_PORT=0
PROXY_USERNAME=""
PROXY_PASSWORD=""

# Webshare.io Proxy Rotation
WEBSHARE_API_KEY=""

# Puppeteer (optional)
PUPPETEER_HEADLESS=true
PUPPETEER_EXECUTABLE_PATH=""
